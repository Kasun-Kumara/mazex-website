# Appwrite endpoint used by the server-side auth flow.
# `/v1` is appended automatically if you omit it.
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1

# Appwrite project that owns the admin users.
APPWRITE_PROJECT_ID=your_project_id

# Server API key with at least the `sessions.write` scope.
APPWRITE_API_KEY=your_sessions_write_api_key

# Label required on the Appwrite user before /admin access is granted.
APPWRITE_ADMIN_LABEL=admin
